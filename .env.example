# ── Shared ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Frontend (Next.js) ──────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:4000
BOOKING_SERVICE_URL=http://booking-service:3001

# Cognito (create a Cognito User Pool in AWS console first)
COGNITO_DOMAIN=https://stagepass.auth.us-east-1.amazoncognito.com
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-client-id
COGNITO_CLIENT_SECRET=your-client-secret
COGNITO_REGION=us-east-1

# ── Booking Service ──────────────────────────────────────────────────
DATABASE_URL=postgresql://stagepass:stagepass@localhost:5432/stagepass_dev
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
REDIS_URL=redis://localhost:6379
WS_MODE=local
WS_SERVER_URL=http://localhost:4000
NODE_ENV=development
LOG_LEVEL=debug

# ── Production only (not needed for local dev) ────────────────────────
# SNS_SEAT_CHANGED_TOPIC_ARN=arn:aws:sns:us-east-1:...
